<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>GuideRailCalculator</title>

<style>
body {
  font-family: Arial, sans-serif;
  padding: 10px;
  max-width: 420px;
  margin: auto;
  background-color: #2C2C2C;
  color: #E0E0E0;
}

h3 {
  color: #FFFFFF;
  text-align: center;
  margin-bottom: 20px;
}

label {
  display: block;
  margin-top: 10px;
  font-size: 14px;
  font-weight: bold;
  color: #B0B0B0;
}

select, input {
  width: 100%;
  padding: 10px;
  font-size: 16px;
  margin-top: 5px;
  box-sizing: border-box;
  border: 1px solid #444;
  border-radius: 4px;
  background-color: #3A3A3A;
  color: #FFFFFF;
}

.result {
  margin-top: 20px;
  padding: 15px;
  background-color: #3A3A3A;
  border-left: 4px solid #4CAF50;
  font-size: 16px;
  border-radius: 4px;
  color: #FFFFFF;
}
</style>
</head>

<body>

<h3>GuideRailCalculator</h3>

<label>Banda:</label>
<select id="item">
  <option value="XLRS_15">XLRS 15</option>
</select>

<label>Orientacja gięcia:</label>
<select id="orientation">
  <option value="horizontal">Horizontal</option>
  <option value="vertical">Vertical</option>
</select>

<label>Promień:</label>
<input type="number" id="radius" placeholder="Wprowadź promień" oninput="calc()">

<label>Długość łuku:</label>
<input type="number" id="arcLength" placeholder="Wprowadź długość łuku" oninput="calc()">

<div class="result" id="out">Wynik pojawi się tutaj...</div>

<script>
function calc() {
  const r = parseFloat(document.getElementById("radius").value);
  const L = parseFloat(document.getElementById("arcLength").value);

  if (isNaN(r) || isNaN(L)) {
    document.getElementById("out").innerHTML = "⚠️ Wprowadź wszystkie wartości";
    return;
  }

  // B3 = kąt łuku (w stopniach)
  const angleDeg = L * (180 / Math.PI);

  // B4 = długość gięcia
  const bendLength = (L * r) / (r + 15);

  // wynik końcowy
  const result = 3996 * (angleDeg * Math.PI / 180) / bendLength;

  document.getElementById("out").innerHTML = `
    ✅ <strong>Wynik:</strong> ${result.toFixed(2)}<br><br>

    <strong>Kąt łuku:</strong> ${angleDeg.toFixed(2)}°<br>
    <strong>Długość gięcia:</strong> ${bendLength.toFixed(2)}<br>

    <small>
      (3996 × radiany(${angleDeg.toFixed(2)}) / ${bendLength.toFixed(2)})
    </small>
  `;
}
</script>

</body>
</html>
